//
//  secrets.example.xcconfig
//  AlphaG3n
//
//  Copy this file to `secrets.xcconfig` (which is gitignored) and fill in
//  real values. Xcode uses it as the base configuration for the AlphaG3n
//  target, and Info.plist substitutes the values at build time so they show
//  up in `Bundle.main.infoDictionary` at runtime — see `Secrets.swift`.
//

JINA_API_KEY = your-jina-key-here
PADDLE_API_KEY = your-paddle-key-here

// Modal PaddleOCR-VL deployment (see modal_paddleocr_vl.py). MODAL_OCR_URL is
// the Pipeline.parse web-endpoint HOST, stored WITHOUT the https:// scheme —
// xcconfig reads `//` as a comment and would truncate a full URL. The scheme
// is prepended in code (ModalOCRClient.makeDefault). Example (host only):
//   your-workspace--paddleocr-vl-pipeline-parse.modal.run
// MODAL_OCR_TOKEN is optional — leave blank for an unauthenticated endpoint.
MODAL_OCR_URL = your-workspace--paddleocr-vl-pipeline-parse.modal.run
MODAL_OCR_TOKEN =
